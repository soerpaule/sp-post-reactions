{
	"name": "soerpaule/sppostreaction",
	"type": "phpbb-extension",
	"description": "Adds AJAX-powered post reactions to phpBB 3.3 with notifications, configurable icon sets, and ACP/UCP integration.",
	"homepage": "https://ext.soerpaule.de",
	"version": "1.0.3",
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "soerpaule",
			"role": "Extension Developer"
		}
	],
	"support": {
		"issues": "https://github.com/soerpaule/sp-post-reactions/issues",
		"source": "https://github.com/soerpaule/sp-post-reactions"
	},
	"require": {
		"php": ">=7.2.0",
		"composer/installers": "~1.0"
	},
	"extra": {
		"display-name": "SP Post Reactions",
		"soft-require": {
			"phpbb/phpbb": ">=3.3.0,<3.4.0@dev"
		}
	}
}
